{
  "env": {
    "node": true,
    "jest": true,
    "es2024": true
  },
  "extends": [
    "eslint:recommended"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "commonjs"
  },
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_|^next$"
      }
    ]
  },
  "ignorePatterns": [
    "node_modules/",
    "coverage/"
  ]
}